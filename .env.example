OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
GOOGLE_AUTH_MODE=oauth
# Shared Driveでサービスアカウントを使う場合だけ設定
GOOGLE_DRIVE_FOLDER_ID=
PDF_PREVIEW_BROWSER=

# 通常は未設定でOK。未設定の場合はOS標準のアプリ用ディレクトリを使います。
# プロジェクト内に保存したい場合だけ、DATABASE_PATH/DRAFTS_DIR/OUTPUT_DIR を指定してください。
# GOOGLE_OAUTH_CLIENT_PATH=
# GOOGLE_OAUTH_TOKEN_PATH=
# GOOGLE_APPLICATION_CREDENTIALS=
# DATABASE_PATH=
# COMPANY_CONFIG_PATH=
# DRAFTS_DIR=
# OUTPUT_DIR=
